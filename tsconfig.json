{
	"compilerOptions": {
		"target": "es2022",
		"module": "commonJs",
		"rootDir": "./src",
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"outDir": "./build",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
		//  "types": ["node"]
	},
	"include": ["src/**/*"]
}
